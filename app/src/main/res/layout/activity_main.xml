<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0a0a0a"
    android:gravity="center" android:padding="32dp">

    <TextView android:text="VOID"
        android:textColor="#555555" android:textSize="13sp"
        android:letterSpacing="0.3" android:layout_marginBottom="48dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <!-- Orb button -->
    <FrameLayout android:id="@+id/orbBtn"
        android:layout_width="160dp" android:layout_height="160dp"
        android:background="@drawable/orb_bg"
        android:clickable="true" android:focusable="true">
    </FrameLayout>

    <TextView android:id="@+id/statusText"
        android:text="Kopfhörer-Taste drücken"
        android:textColor="#666666" android:textSize="14sp"
        android:layout_marginTop="24dp" android:gravity="center"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <Button android:id="@+id/convBtn"
        android:text="Konversation"
        android:layout_marginTop="32dp"
        android:backgroundTint="#1a1a1a"
        android:textColor="#7c6df0"
        android:layout_width="200dp" android:layout_height="48dp"/>

    <TextView android:text="Backend URL"
        android:textColor="#444" android:textSize="11sp"
        android:layout_marginTop="48dp" android:layout_marginBottom="6dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <EditText android:id="@+id/backendUrl"
        android:hint="https://your-app.railway.app"
        android:textColor="#aaaaaa" android:textColorHint="#444"
        android:textSize="13sp" android:background="#141414"
        android:padding="12dp"
        android:inputType="textUri"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

</LinearLayout>
